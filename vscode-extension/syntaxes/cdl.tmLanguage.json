{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CDL",
  "scopeName": "source.cdl",
  "fileTypes": [".cdl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#identifiers" },
    { "include": "#v06-features" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.cdl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.cdl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "meta.annotation.cdl",
          "match": "(@(lang|source|timeout|cache|style|color|animation|interaction|title|subtitle|layout|theme|grid))\\s*(\\([^)]*\\))?",
          "captures": {
            "1": { "name": "storage.modifier.cdl" },
            "3": { "name": "meta.annotation.parameters.cdl" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.declaration.cdl",
          "match": "\\b(Data|Chart)\\b"
        },
        {
          "name": "keyword.control.cdl",
          "match": "\\b(use|type|x|y|group|stack|where|as)\\b"
        },
        {
          "name": "keyword.other.charttype.cdl",
          "match": "\\b(line|bar|pie|scatter|area|radar|heatmap|combo|gauge|candlestick|boxplot|sankey|treemap|wordcloud|liquid|map)\\b"
        }
      ]
    },
    "v06-features": {
      "patterns": [
        {
          "name": "keyword.control.v06.cdl",
          "match": "^##\\s+(series|axis)\\b"
        },
        {
          "name": "support.type.axis-position.cdl",
          "match": "\\b(x|y|y2|x2|left|right|top|bottom)\\b"
        },
        {
          "name": "support.constant.axis-type.cdl",
          "match": "\\b(category|value|time|log)\\b"
        },
        {
          "name": "support.type.series-style.cdl",
          "match": "\\b(solid|dashed|smooth|marker)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.cdl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.cdl",
          "match": "\\\\."
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.cdl",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "identifiers": {
      "name": "variable.other.cdl",
      "match": "[a-zA-Z_][a-zA-Z0-9_]*"
    }
  }
}