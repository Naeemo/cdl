{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CDL",
  "scopeName": "source.cdl",
  "fileTypes": [".cdl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#title" },
    { "include": "#charttype" },
    { "include": "#sections" },
    { "include": "#directives" },
    { "include": "#table" },
    { "include": "#strings" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.cdl", "match": "//.*$" },
        { "name": "comment.block.cdl", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "title": {
      "match": "^(#)\\s+(.*)$",
      "captures": {
        "1": { "name": "markup.heading.cdl" },
        "2": { "name": "entity.name.function.cdl" }
      }
    },
    "charttype": {
      "match": "^(##)\\s+(line|bar|pie|scatter|area|radar|heatmap|combo|gauge|candlestick|boxplot|sankey|treemap|wordcloud|liquid|map|funnel|sunburst|graph|parallel)$",
      "captures": {
        "1": { "name": "markup.heading.cdl" },
        "2": { "name": "keyword.other.charttype.cdl" }
      }
    },
    "sections": {
      "match": "^(##)\\s+(series|axis|map|data)$",
      "captures": {
        "1": { "name": "markup.heading.cdl" },
        "2": { "name": "keyword.control.cdl" }
      }
    },
    "directives": {
      "match": "(@(style|color|animation|title|subtitle|layout|theme|grid|interaction|locale|responsive))\\s*(\"[^\"]*\"|'[^']*'|\\S+)?",
      "captures": {
        "1": { "name": "storage.modifier.cdl" },
        "2": { "name": "string.quoted.cdl" }
      }
    },
    "table": {
      "begin": "^\\|",
      "end": "\\|$",
      "patterns": [
        { "name": "punctuation.definition.table.cdl", "match": "\\|" },
        { "name": "string.other.table-cell.cdl", "match": "[^|]+" }
      ]
    },
    "strings": {
      "name": "string.quoted.double.cdl",
      "begin": "\"",
      "end": "\""
    },
    "numbers": {
      "name": "constant.numeric.cdl",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  }
}
