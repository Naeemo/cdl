{
  "name": "cdl-vscode",
  "displayName": "CDL Language Support",
  "description": "Chart Definition Language support for VS Code",
  "version": "0.1.0",
  "publisher": "cdl",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "cdl",
      "aliases": ["CDL", "cdl"],
      "extensions": [".cdl"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "cdl",
      "scopeName": "source.cdl",
      "path": "./syntaxes/cdl.tmLanguage.json"
    }],
    "snippets": [{
      "language": "cdl",
      "path": "./snippets/cdl.json"
    }]
  }
}
