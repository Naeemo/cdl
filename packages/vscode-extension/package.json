{
  "name": "cdl-vscode",
  "displayName": "CDL - Chart Definition Language",
  "description": "VS Code support for Chart Definition Language",
  "version": "0.1.0",
  "publisher": "naeemo",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Snippets"
  ],
  "keywords": [
    "cdl",
    "chart",
    "echarts",
    "data visualization",
    "dsl"
  ],
  "activationEvents": [
    "onLanguage:cdl"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "cdl",
        "aliases": [
          "Chart Definition Language",
          "cdl"
        ],
        "extensions": [
          ".cdl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/cdl-light.svg",
          "dark": "./icons/cdl-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "cdl",
        "scopeName": "source.cdl",
        "path": "./syntaxes/cdl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "cdl.preview",
        "title": "CDL: Preview Chart",
        "icon": "$(preview)"
      },
      {
        "command": "cdl.compile",
        "title": "CDL: Compile to JSON"
      },
      {
        "command": "cdl.exportECharts",
        "title": "CDL: Export ECharts Config"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "cdl.preview",
          "group": "navigation",
          "when": "resourceExtname == .cdl"
        }
      ],
      "commandPalette": [
        {
          "command": "cdl.preview",
          "when": "resourceExtname == .cdl"
        },
        {
          "command": "cdl.compile",
          "when": "resourceExtname == .cdl"
        },
        {
          "command": "cdl.exportECharts",
          "when": "resourceExtname == .cdl"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cdl.preview",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorTextFocus && resourceExtname == .cdl"
      }
    ],
    "configuration": {
      "title": "CDL",
      "properties": {
        "cdl.preview.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto refresh preview on file change"
        },
        "cdl.preview.theme": {
          "type": "string",
          "default": "light",
          "enum": [
            "light",
            "dark"
          ],
          "description": "Chart preview theme"
        }
      }
    },
    "snippets": [
      {
        "language": "cdl",
        "path": "./snippets/cdl.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "@cdl/compiler": "file:../compiler",
    "@cdl/renderer-echarts": "file:../renderer"
  }
}