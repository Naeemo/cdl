{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node"
  },
  "include": ["*.ts", "src/v06-parser.ts", "src/types.ts"],
  "exclude": ["node_modules", "dist", "error-hints.ts", "transform.ts", "fetcher.ts", "websocket.ts", "performance.ts"]
}
