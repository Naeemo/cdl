@lang(data)
StockPrices {
    date,ticker,open,high,low,close,volume
    2026-03-12,ticker_1,open_1,high_1,low_1,close_1,9471
    2026-03-13,ticker_2,open_2,high_2,low_2,close_2,1239
    2026-03-14,ticker_3,open_3,high_3,low_3,close_3,6600
    2026-03-15,ticker_4,open_4,high_4,low_4,close_4,3034
    2026-03-16,ticker_5,open_5,high_5,low_5,close_5,1054
}

Chart {
    use StockPrices
    type boxplot
    x date
    y volume
    @title "价格走势 - BOXPLOT"
    @style "箱线图，统计分布"
    @color "#ee6666"
}