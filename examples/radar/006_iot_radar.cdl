@lang(data)
SensorData {
    timestamp,sensor_id,temperature,humidity,status
    2026-03-12,sensor_id_1,94,humidity_1,active
    2026-03-13,sensor_id_2,89,humidity_2,inactive
    2026-03-14,sensor_id_3,79,humidity_3,active
