// 示例：简单的正弦波
// 查询类型：裸数据
// 图表类型：折线图

@lang(data)
SineWave {
    x,y
    0,0
    30,0.5
    60,0.87
    90,1
    120,0.87
    150,0.5
    180,0
    210,-0.5
    240,-0.87
    270,-1
    300,-0.87
    330,-0.5
    360,0
}

Chart {
    use SineWave
    type line
    x x
    y y
    
    @style "平滑曲线，数学函数可视化"
    @color "#9b59b6"
}
