// 示例：项目进度甘特图风格
// 查询类型：裸数据
// 图表类型：横向柱状图

@lang(data)
ProjectTasks {
    task,start_day,duration
    需求分析,0,5
    系统设计,5,7
    开发实现,10,20
    测试验证,28,10
    部署上线,35,3
}

Chart {
    use ProjectTasks
    type bar
    x duration
    y task
    
    @style "甘特图风格，显示开始位置和持续时间"
    @color "不同阶段不同颜色"
    @title "项目进度计划"
}
